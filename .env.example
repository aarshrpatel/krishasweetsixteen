# Postgres connection string (Neon free tier — provision via Vercel Marketplace)
DATABASE_URL=

# Admin login password (any string — set this to gate /admin)
ADMIN_PASSWORD=

# HMAC secret for signing the admin session cookie (any long random string)
ADMIN_SECRET=

# Public URL of the deployed site (used to build RSVP links shown in /admin)
# Vercel sets NEXT_PUBLIC_VERCEL_URL automatically; set this for local/custom domains.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
